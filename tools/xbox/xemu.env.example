# xemu.env.example — copy to tools/xbox/xemu.env and edit for your machine.
# tools/xbox/xemu.env is gitignored.
#
# Only two paths are needed: xemu itself and its xemu.toml (which holds
# bios, hdd, eeprom, avpack etc.). Configure those via the xemu GUI once
# and they persist.
#
# On WSL, XEMU_BIN is the Windows .exe accessed via /mnt/c/... and
# XEMU_TOML is under /mnt/c/Users/<you>/AppData/Roaming/xemu/xemu/xemu.toml.
# On native Linux/macOS, use POSIX paths.

# xemu executable
XEMU_BIN="/mnt/c/Users/you/Downloads/xemu-0.8.134-windows-x86_64/xemu.exe"

# xemu settings file — the script updates dvd_path here before launching.
XEMU_TOML="/mnt/c/Users/you/AppData/Roaming/xemu/xemu/xemu.toml"
