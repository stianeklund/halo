{
  "mcpServers": {
    "qmd": {
      "command": "qmd",
      "args": ["mcp"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && tools/shell/mcp-servers.sh start xemu 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "Ensuring xemu MCP daemon is running"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && rtk python3 tools/audit/token_discipline_hook.py",
            "timeout": 10,
            "statusMessage": "Token-discipline tracker"
          }
        ]
      },
      {
        "matcher": "mcp__ghidra__decompile_function|mcp__ghidra__batch_decompile|mcp__ghidra__force_decompile",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && python3 tools/retrieval/decompile_hook.py",
            "timeout": 15,
            "statusMessage": "Retrieval: finding similar ported functions"
          },
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && python3 tools/retrieval/enrichment_hook.py",
            "timeout": 5,
            "statusMessage": "Enrichment: injecting cached callee/struct/alias analysis"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && rtk python3 tools/audit/token_discipline_hook.py",
            "timeout": 10,
            "statusMessage": "Emit token-discipline summary"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && rtk python3 tools/audit/token_discipline_hook.py",
            "timeout": 10,
            "statusMessage": "Emit token-discipline summary"
          }
        ]
      }
    ]
  }
}
